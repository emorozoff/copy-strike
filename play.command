#!/bin/bash
# Copy-Strike — локальный запуск. Двойной клик по этому файлу в Finder.
# Браузер не даёт открыть игру напрямую (file://) — модули блокируются CORS,
# поэтому поднимаем крошечный локальный сервер и открываем его в браузере.
cd "$(dirname "$0")" || exit 1
PORT=8000

# освобождаем порт, если сервер уже запущен
lsof -ti:$PORT 2>/dev/null | xargs kill 2>/dev/null

echo "======================================"
echo "  COPY-STRIKE — локальный запуск"
echo "  http://localhost:$PORT/"
echo "  (не закрывай это окно, пока играешь)"
echo "======================================"

# запускаем сервер и открываем браузер
python3 -m http.server $PORT --bind 127.0.0.1 >/dev/null 2>&1 &
SRV=$!
sleep 1
open "http://localhost:$PORT/"

echo "Сервер работает (PID $SRV). Закрой окно/нажми Ctrl+C, чтобы остановить."
# держим окно открытым, пока работает сервер
wait $SRV
